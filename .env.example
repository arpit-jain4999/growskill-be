# Server
PORT=8080
NODE_ENV=development

# JWT / DB (set your values)
# JWT_SECRET=
# DB_USER_NAME=
# DB_PASSWORD=
# DB_CLUSTER_NAME=
# DB_NAME=

# ---------- Storage ----------
# Force local disk (see LOCAL_UPLOADS_ROOT) even if bucket is set
# STORAGE_USE_LOCAL=true

# Local disk paths (optional). Defaults: <os-temp>/growskill-be/uploads and .../hls
# so `nest start --watch` does not restart when transcoding writes files under the repo.
# LOCAL_UPLOADS_ROOT=./storage/uploads
# VIDEO_HLS_OUTPUT_DIR=./storage/hls

# AWS S3 — set bucket + region to enable S3 (unset STORAGE_USE_LOCAL)
AWS_S3_BUCKET=
FILE_BUCKET_NAME=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Public URL for stored objects (CloudFront recommended in production)
FILE_BASE_URL=

# Presigned PUT expiry (seconds)
S3_PRESIGNED_EXPIRES_SEC=3600

# MinIO / LocalStack (optional)
# AWS_S3_ENDPOINT=http://127.0.0.1:9000
# AWS_S3_FORCE_PATH_STYLE=true

# --- HLS ---
# With S3 enabled (default): after transcoding, playlists + segments are uploaded under {HLS_S3_KEY_PREFIX}/{videoProcessingId}/
# and hlsMasterUrl uses FILE_BASE_URL (or S3 virtual host). Optional override for a different CDN:
# HLS_S3_PUBLIC_BASE_URL=https://dxxxx.cloudfront.net
# HLS_UPLOAD_TO_S3=false   # keep HLS only on API disk (use HLS_PUBLIC_BASE_URL for /hls/)
# HLS_S3_KEY_PREFIX=hls    # S3 key prefix (default hls)
# HLS_DELETE_LOCAL_AFTER_S3_UPLOAD=false  # keep local copy after upload (default: delete to save disk)

# Local disk only (no S3): serve /hls/ from this API — set origin explicitly if not localhost:
# HLS_PUBLIC_BASE_URL=http://localhost:8080
